{
  "name": "penjj-blog",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "description": "My personal website and blog.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "prepare": "simple-git-hooks",
    "ts-check": "tsc --noEmit && astro check --noEmit",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "astro": "^5.7.13",
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.1",
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.2.6",
    "@astrojs/solid-js": "^5.0.10",
    "@iconify-json/bi": "^1.2.4",
    "@iconify-json/lucide": "^1.2.44",
    "@iconify-json/material-symbols": "^1.2.21",
    "@iconify-json/material-symbols-light": "^1.2.21",
    "@penjj/unocss-attributify": "^0.0.4",
    "@types/node": "^22.15.21",
    "@unocss/reset": "^66.1.2",
    "bumpp": "^10.1.1",
    "cssnano": "^7.0.7",
    "eslint-plugin-format": "^1.0.1",
    "lint-staged": "^16.0.0",
    "postcss-nested": "^7.0.2",
    "prettier-plugin-astro": "^0.14.1",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "unocss": "^66.1.2",
    "unocss-preset-forme": "^0.0.4",
    "vue-commitlint": "^0.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm vue-commitlint"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": [
      "eslint --fix"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
